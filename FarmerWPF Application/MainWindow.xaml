<Window x:Class="FarmerWPF_Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FarmerWPF_Application"
        mc:Ignorable="d"
        Title="FarmersWindow" Height="400" Width="800">
    <Grid ShowGridLines="False">
        <Grid.Background>
            <RadialGradientBrush>
                <GradientStop Color="Black" Offset="1"/>
                <GradientStop Color="Red"/>
            </RadialGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width ="*"/>
            <ColumnDefinition Width ="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height = "50"/>
            <RowDefinition Height = "50"/>
            <RowDefinition Height = "Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Farmer's Name:" FontFamily="Nirmala UI" Width="180" FontSize="20" FontWeight="Bold" Margin="10" Background="Red" Foreground="White"/>
            <TextBox x:Name="txtFarmerName" TextWrapping="Wrap" Width="180" FontFamily="Nirmala UI" FontSize="24" FontWeight="Bold" Margin="10"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1">
            <TextBlock Text="Surname:" FontFamily="Nirmala UI" FontSize="24" Width="180" FontWeight="Bold" Margin="10" Background="Red" Foreground="White"/>
            <TextBox x:Name="txtFarmerSurname" TextWrapping="Wrap" Width="180" FontFamily="Nirmala UI" FontSize="24" FontWeight="Bold" Margin="10"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="0">
            <TextBlock Text="Farm Code:" FontFamily="Nirmala UI" FontSize="24" Width="180" FontWeight="Bold" Margin="10" Background="Red" Foreground="White"/>
            <TextBox x:Name="txtFarmCode" TextWrapping="Wrap" Width="180" FontFamily="Nirmala UI" FontSize="24" FontWeight="Bold" Margin="10"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1">
            <TextBlock Text="No. Of Crops:" FontFamily="Nirmala UI" FontSize="24" Width="180" TextAlignment="Left" FontWeight="Bold" Margin="10" Background="Red" Foreground="White"/>
            <TextBox x:Name="txtNumOfCrops" TextWrapping="Wrap" Width="180" FontFamily="Nirmala UI" FontSize="24" FontWeight="Bold" Margin="10"/>
        </StackPanel>


        <StackPanel Orientation="Vertical" Grid.Row="2" Grid.Column="0">
            <Button x:Name="btnSave" Content="Save" Height="30" Width="350" Margin="10" FontFamily="Nirmala UI" FontSize="20" Click="btnSave_Click"/>
            <Button x:Name="btnCalculate" Content="Calculate" Height="30" Width="350" Margin="10" FontFamily="Nirmala UI" FontSize="20"/>
            <Button x:Name="btnShowResults" Content="Show Results" Height="30" Width="350" Margin="10" FontFamily="Nirmala UI" FontSize="20" Click="btnShowResults_Click"/>
            <Button x:Name="btnClear" Content="Clear" Height="30" Width="350" Margin="10" FontFamily="Nirmala UI" FontSize="20" Click="btnClear_Click"/>
            <Button x:Name="btnExit" Content="Exit" Height="30" Width="350" Margin="10" FontFamily="Nirmala UI" FontSize="20" Click="btnExit_Click" Background="#FFFF3B3B" Foreground="White"/>
        </StackPanel>

        <ListBox Name="lstDisplay" Grid.Row="2" Grid.Column="1" Margin="10" FontFamily="Nirmala UI" FontSize="20"/>
    </Grid>
</Window>
